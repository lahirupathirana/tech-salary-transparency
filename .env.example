# ===== Tech Salary Transparency - Environment =====
# Copy to ".env" (same directory as docker-compose.yml) before `docker compose up`.

# ---- PostgreSQL ----
POSTGRES_USER=tst_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tst_db

# ---- JWT ----
# Generate a strong secret: `openssl rand -base64 48`
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=12h

# ---- Bcrypt ----
BCRYPT_ROUNDS=10

# ---- Business rules ----
# Number of net up-votes required to auto-approve a PENDING submission.
APPROVAL_THRESHOLD=3
